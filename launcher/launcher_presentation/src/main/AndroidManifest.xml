<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="ly.com.tahaben.launcher_presentation">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE"/>

    <application>
        <activity
            android:name=".wait.DelayedLaunchActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:label="@string/title_activity_hold_up"
            android:theme="@style/Theme.Farhan" />
        <!-- Empty taskAffinity: the overlay must open in its own task so finishing it
             reveals whatever the user was in before locking, instead of dragging the
             rest of the Farhan task (MainActivity) to the foreground with it. -->
        <activity
            android:name=".wait.DelayedUnlockActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:label="@string/title_activity_hold_up"
            android:theme="@style/Theme.Farhan" />
    </application>

</manifest>